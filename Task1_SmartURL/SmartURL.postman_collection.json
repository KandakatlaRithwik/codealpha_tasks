{
  "info": {
    "name": "SmartURL API",
    "description": "SmartURL - Advanced URL Shortener & Analytics Platform - Full API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "urlId", "value": "" },
    { "key": "shortCode", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.data.token);",
                  "  pm.collectionVariables.set('userId', data.data.user._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.data.token);",
                  "  pm.collectionVariables.set('userId', data.data.user._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "Generate API Key",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/api-key"
          }
        }
      ]
    },
    {
      "name": "URLs",
      "item": [
        {
          "name": "Create Short URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/urls",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"https://www.example.com/some/very/long/path\",\n  \"customAlias\": \"my-link\",\n  \"expiryOption\": \"7d\",\n  \"tags\": [\"marketing\", \"campaign\"],\n  \"category\": \"marketing\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('urlId', data.data.url._id);",
                  "  pm.collectionVariables.set('shortCode', data.data.url.shortCode);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Bulk Create URLs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/urls/bulk",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"urls\": [\n    { \"originalUrl\": \"https://example.com/a\" },\n    { \"originalUrl\": \"https://example.com/b\", \"customAlias\": \"link-b\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All URLs (search/filter/paginate)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/urls?page=1&limit=10&status=active&sortBy=clickCount&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "active" },
                { "key": "sortBy", "value": "clickCount" },
                { "key": "order", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get URL By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}"
          }
        },
        {
          "name": "Update URL",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/urls/{{urlId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"updated-category\",\n  \"isFavorite\": true\n}"
            }
          }
        },
        {
          "name": "Activate URL",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}/activate"
          }
        },
        {
          "name": "Deactivate URL",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}/deactivate"
          }
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}/favorite"
          }
        },
        {
          "name": "Get QR Code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}/qr"
          }
        },
        {
          "name": "Regenerate QR Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}/qr/regenerate"
          }
        },
        {
          "name": "Delete URL",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/urls/{{urlId}}"
          }
        }
      ]
    },
    {
      "name": "Redirection",
      "item": [
        {
          "name": "Redirect to Original URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/{{shortCode}}"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics"
          }
        },
        {
          "name": "Top URLs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics/top-urls?order=most&limit=10"
          }
        },
        {
          "name": "URL Analytics Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics/{{urlId}}"
          }
        },
        {
          "name": "Click History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics/{{urlId}}/history?page=1&limit=20"
          }
        },
        {
          "name": "Export Analytics CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics/{{urlId}}/export"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/stats"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/users?page=1&limit=10"
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/block"
          }
        },
        {
          "name": "Unblock User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/unblock"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/users/{{userId}}"
          }
        },
        {
          "name": "Get All URLs (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/urls?page=1&limit=10"
          }
        },
        {
          "name": "Delete Any URL (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/urls/{{urlId}}"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
