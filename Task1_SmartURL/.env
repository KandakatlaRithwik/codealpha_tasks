NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000

# Local MongoDB (change if you run Atlas or another host)
MONGO_URI=mongodb://127.0.0.1:27017/smarturl

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Default short code length
SHORT_CODE_LENGTH=7
